# Abacus - Matt Gates Financial Data
# Three organizations: RCR LLC, Kalshi Trading, Personal
# Copy to .env and fill in real values

# Database (SQLite for local dev, PostgreSQL for Docker production)
DATABASE_URL=sqlite+aiosqlite:///data/ridge_cell_repair.db
# DATABASE_URL=postgresql+asyncpg://abacus:PASSWORD@localhost:5432/abacus_rcr

# Security
SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# AI (for transaction classification)
ANTHROPIC_API_KEY=sk-ant-...
SONNET_MODEL=claude-sonnet-4-20250514

# Docker PostgreSQL (only needed for docker-compose)
POSTGRES_PASSWORD=CHANGE-ME
